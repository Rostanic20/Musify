# Server
SERVER_HOST=0.0.0.0
SERVER_PORT=8080
ENVIRONMENT=development
API_BASE_URL=http://localhost:8080

# Database
DATABASE_URL=jdbc:postgresql://localhost:5432/musify
DATABASE_USER=musify_user
DATABASE_PASSWORD=musify_pass

# JWT (change in production)
JWT_SECRET=development-secret-key-change-in-production

# Redis
REDIS_ENABLED=false
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=musify_redis

# Storage
STORAGE_TYPE=local
LOCAL_STORAGE_PATH=./uploads

# Email (disabled by default)
EMAIL_ENABLED=false

# Stripe (optional)
STRIPE_API_KEY=
STRIPE_WEBHOOK_SECRET=

# Monitoring (disabled by default)
MONITORING_ENABLED=false
SENTRY_DSN=

# Feature Flags
FEATURE_OAUTH_ENABLED=false
FEATURE_2FA_ENABLED=false
FEATURE_SOCIAL_ENABLED=true
FEATURE_OFFLINE_MODE_ENABLED=false
